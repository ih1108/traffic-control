# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/traffic_control

# Environment
ENV=development

# Server
HOST=0.0.0.0
PORT=8000

# TAGO (국가교통정보센터) API
TAGO_API_KEY=YOUR_API_KEY
TAGO_BASE_URL=https://openapi.its.go.kr:9443
TAGO_TRAFFIC_INFO_ENDPOINT=/api/TrafficInfo
TAGO_TRAFFIC_FORECAST_ENDPOINT=/api/TrafficForecast
TAGO_CCTV_ENDPOINT=/cctvInfo
TAGO_CCTV_QUERY_TYPE=all
TAGO_CCTV_TYPE=1
TAGO_CCTV_MIN_X=126.8
TAGO_CCTV_MAX_X=127.2
TAGO_CCTV_MIN_Y=37.4
TAGO_CCTV_MAX_Y=37.7